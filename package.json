{
  "name": "bread-events",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./tailwind-built.css --minify",
    "build:js": "esbuild src/app.jsx --bundle --outfile=app.bundle.js --minify --loader:.jsx=jsx --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\"",
    "build": "npm run build:css && npm run build:js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "tailwindcss": "^3.4.17"
  }
}
